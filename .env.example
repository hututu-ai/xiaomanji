# 复制为 .env：  cp .env.example .env
# aiping.cn 网关 API Key（OpenAI 兼容）。服务器端使用，不带 VITE_ 前缀 → 不会泄露到前端。
AI_API_KEY=your_api_key_here

# （可选）覆盖前端调用的中转端点，默认 /api/ai
# VITE_AI_ENDPOINT=/api/ai

# OpenAI TTS：小满说话功能使用。Cloudflare Pages 也要配置同名环境变量。
OPENAI_API_KEY=your_openai_api_key_here

# （可选）调整小满 TTS 的模型和音色
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=shimmer
